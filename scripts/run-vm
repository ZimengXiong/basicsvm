#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
system="${1:-x86_64}"
profile="${2:-full}"

case "$system" in
  x86_64)
    case "$profile" in
      full) result="$repo_root/out/result-vm-x86_64"; log_name="vm-x86_64.log" ;;
      smoke) result="$repo_root/out/result-vm-smoke-x86_64"; log_name="vm-smoke-x86_64.log" ;;
      *) echo "usage: scripts/run-vm [x86_64|aarch64] [full|smoke]" >&2; exit 2 ;;
    esac
    ;;
  aarch64|arm64)
    case "$profile" in
      full) result="$repo_root/out/result-vm-aarch64"; log_name="vm-aarch64.log" ;;
      smoke) result="$repo_root/out/result-vm-smoke-aarch64"; log_name="vm-smoke-aarch64.log" ;;
      *) echo "usage: scripts/run-vm [x86_64|aarch64] [full|smoke]" >&2; exit 2 ;;
    esac
    ;;
  *)
    echo "usage: scripts/run-vm [x86_64|aarch64] [full|smoke]" >&2
    exit 2
    ;;
esac

mkdir -p "$repo_root/out"

export QEMU_OPTS="${QEMU_OPTS:-} -display vnc=0.0.0.0:1"
exec "$repo_root/scripts/nix" shell nixpkgs#bash --command bash -lc '
  set -euo pipefail
  result="$1"
  log="$2"
  runner="$(find -L "$result/bin" -maxdepth 1 -type f -name "run-*-vm" -print -quit)"
  if [[ -z "$runner" ]]; then
    echo "VM runner not found in $result/bin" >&2
    exit 1
  fi
  exec "$runner" 2>&1 | tee "$log"
' bash "$result" "$repo_root/out/$log_name"
