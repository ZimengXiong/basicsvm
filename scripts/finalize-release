#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

source_root="$repo_root/out/release"
final_root="$repo_root/out/final"

usage() {
  cat >&2 <<'EOF'
usage: scripts/finalize-release [options]

Options:
  --source DIR   per-target package root, default: out/release
  --out DIR      final upload root, default: out/final

Collects the supported release target images into one upload-ready tree.
Run this after scripts/build-release has produced the target packages.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --source)
      source_root="${2:?missing --source value}"
      shift 2
      ;;
    --out)
      final_root="${2:?missing --out value}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "unknown option: $1" >&2
      usage
      exit 2
      ;;
  esac
done

copy_target() {
  local target="$1"
  local format="$2"
  local image_glob="$3"
  local bundle_glob="${4:-}"
  local source_dir="$source_root/$target/$format"
  local checksum_dir="$source_root/$target/checksums"
  local dest_dir="$final_root/$target"

  if [[ ! -d "$source_dir" ]]; then
    echo "missing package directory for $target: $source_dir" >&2
    exit 1
  fi

  shopt -s nullglob
  local images=("$source_dir"/$image_glob)
  shopt -u nullglob

  if [[ "${#images[@]}" -ne 1 ]]; then
    echo "expected exactly one $image_glob for $target in $source_dir" >&2
    exit 1
  fi

  rm -rf "$dest_dir"
  mkdir -p "$dest_dir"
  cp -f "${images[0]}" "$dest_dir/"
  if [[ -n "$bundle_glob" ]]; then
    shopt -s nullglob
    local bundles=("$source_dir"/$bundle_glob)
    shopt -u nullglob
    if [[ "${#bundles[@]}" -ne 1 ]]; then
      echo "expected exactly one $bundle_glob for $target in $source_dir" >&2
      exit 1
    fi
    cp -f "${bundles[0]}" "$dest_dir/"
  fi
  cp -f "$source_dir/README.txt" "$dest_dir/"
  if [[ -f "$checksum_dir/SHA256SUMS" ]]; then
    cp -f "$checksum_dir/SHA256SUMS" "$dest_dir/"
  else
    (
      cd "$dest_dir"
      sha256sum "$(basename "${images[0]}")" README.txt > SHA256SUMS
    )
  fi
}

rm -rf "$final_root"
mkdir -p "$final_root"

copy_target macos-apple-silicon utm '*.qcow2' '*.utm.zip'
copy_target macos-intel utm '*.qcow2' '*.utm.zip'
copy_target windows-arm virtualbox '*.vdi'
copy_target windows-x86 virtualbox '*.vdi'
copy_target linux-x86 virtualbox '*.vdi'

cat <<EOF
Final release tree ready:
  $final_root

Targets:
  macos-apple-silicon
  macos-intel
  windows-arm
  windows-x86
  linux-x86
EOF
