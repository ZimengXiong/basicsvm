#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat >&2 <<'EOF'
usage: scripts/package-vm TARGET [options]

Targets:
  macos-apple-silicon   aarch64 zipped UTM bundle
  macos-intel           x86_64 zipped UTM bundle
  windows-x86           x86_64 VirtualBox vdi
  windows-arm           aarch64 VirtualBox vdi
  linux-x86             x86_64 VirtualBox vdi

Options:
  --out DIR                  output directory, default: out/release/TARGET
  --raw PATH                 use an existing raw image instead of building it
  --repart-build-dir DIR     assemble raw image from a kept failed Nix repart build
  --keep-raw                 keep raw image when target normally only needs converted disk
  --archive                  create a .tar.zst release archive
  --ova                      also create a VirtualBox .ova appliance for VirtualBox targets

Examples:
  scripts/package-vm windows-x86
  scripts/package-vm macos-apple-silicon --raw /path/to/basicsvm-aarch64-linux.raw
  scripts/package-vm windows-arm --repart-build-dir /nix/var/nix/builds/nix-...-...
EOF
}

target="${1:-}"
if [[ -z "$target" || "$target" == "-h" || "$target" == "--help" ]]; then
  usage
  exit 0
fi
shift

out=""
raw_input=""
repart_build_dir=""
keep_raw=0
archive=0
ova=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --out)
      out="${2:?missing --out value}"
      shift 2
      ;;
    --raw)
      raw_input="${2:?missing --raw value}"
      shift 2
      ;;
    --repart-build-dir)
      repart_build_dir="${2:?missing --repart-build-dir value}"
      shift 2
      ;;
    --keep-raw)
      keep_raw=1
      shift
      ;;
    --archive)
      archive=1
      shift
      ;;
    --ova)
      ova=1
      shift
      ;;
    *)
      echo "unknown option: $1" >&2
      usage
      exit 2
      ;;
  esac
done

case "$target" in
  macos-apple-silicon)
    nix_system="aarch64-linux"
    arch_name="aarch64"
    format="utm"
    ;;
  macos-intel)
    nix_system="x86_64-linux"
    arch_name="x86_64"
    format="utm"
    ;;
  windows-x86|linux-x86)
    nix_system="x86_64-linux"
    arch_name="x86_64"
    format="virtualbox"
    ;;
  windows-arm)
    nix_system="aarch64-linux"
    arch_name="aarch64"
    format="virtualbox"
    ;;
  *)
    echo "unsupported target: $target" >&2
    usage
    exit 2
    ;;
esac

if [[ -n "$raw_input" && -n "$repart_build_dir" ]]; then
  echo "--raw and --repart-build-dir are mutually exclusive" >&2
  exit 2
fi

out="${out:-$repo_root/out/release/$target}"
raw_dir="$out/raw"
pkg_dir="$out/$format"
checksum_dir="$out/checksums"
mkdir -p "$raw_dir" "$pkg_dir" "$checksum_dir"

require_qemu_img() {
  if ! command -v qemu-img >/dev/null 2>&1; then
    echo "qemu-img is required for $format packaging" >&2
    echo "Install qemu/qemu-utils on this builder, then rerun the same command." >&2
    exit 1
  fi
}

find_systemd_repart() {
  if command -v systemd-repart >/dev/null 2>&1; then
    command -v systemd-repart
    return 0
  fi
  find /nix/store -path '*/bin/systemd-repart' -type f 2>/dev/null | sort | tail -1
}

raw_path="$raw_dir/basicsvm-${arch_name}-linux.raw"
raw_is_external=0

copy_or_decompress_raw() {
  local src="$1"
  case "$src" in
    *.raw)
      raw_path="$(cd "$(dirname "$src")" && pwd)/$(basename "$src")"
      raw_is_external=1
      ;;
    *.raw.zst)
      zstd -d -f "$src" -o "$raw_path"
      ;;
    *)
      echo "expected .raw or .raw.zst, got: $src" >&2
      exit 1
      ;;
  esac
}

find_built_raw() {
  local result_dir="$1"
  local found
  found="$(find "$result_dir" -maxdepth 2 \( -name '*.raw' -o -name '*.raw.zst' \) -type f | head -1)"
  if [[ -z "$found" ]]; then
    echo "Nix image build did not produce a .raw or .raw.zst under $result_dir" >&2
    exit 1
  fi
  printf '%s\n' "$found"
}

assemble_from_repart_build_dir() {
  local build_dir="$1"
  if [[ ! -f "$build_dir/.attrs.sh" || ! -d "$build_dir/amended-repart.d" ]]; then
    echo "not a kept Nix repart build directory: $build_dir" >&2
    exit 1
  fi
  if [[ "$(id -u)" -ne 0 ]]; then
    echo "--repart-build-dir must run as root because systemd-repart mounts loop filesystems." >&2
    echo "Rerun with sudo, preserving this repo path and output path." >&2
    exit 1
  fi
  local work="$raw_dir/repart-work"
  rm -rf "$work" "$raw_path"
  mkdir -p "$work"
  cp -a "$build_dir/amended-repart.d" "$work/repart.d"
  systemd_repart="$(find_systemd_repart)"
  if [[ -z "$systemd_repart" ]]; then
    echo "systemd-repart is required for --repart-build-dir assembly" >&2
    exit 1
  fi
  (
    cd "$work"
    # .attrs.sh is generated by Nix for this exact image derivation.
    # shellcheck disable=SC1091
    source "$build_dir/.attrs.sh"
    "$systemd_repart" "${systemdRepartFlags[@]}" "$raw_path" | tee "$raw_dir/repart-output.json"
  )
}

if [[ -n "$raw_input" ]]; then
  copy_or_decompress_raw "$raw_input"
elif [[ -n "$repart_build_dir" ]]; then
  assemble_from_repart_build_dir "$repart_build_dir"
else
  result_dir="$out/nix-repart-result"
  rm -f "$result_dir"
  if ! "$repo_root/scripts/nix" build ".#packages.${nix_system}.basics-image-repart" -o "$result_dir" --print-build-logs; then
    cat >&2 <<EOF

Nix built the system closure but failed during final image assembly.
If the log says "keeping build directory", rerun this target on the same
builder with:

  sudo $repo_root/scripts/package-vm $target --repart-build-dir /nix/var/nix/builds/...

EOF
    exit 1
  fi
  copy_or_decompress_raw "$(find_built_raw "$result_dir")"
  repart_json="$(find "$result_dir" -maxdepth 2 -name 'repart-output.json' -type f | head -1 || true)"
  if [[ -n "$repart_json" ]]; then
    cp -f "$repart_json" "$raw_dir/repart-output.json"
  fi
fi

require_qemu_img
ova_path=""

case "$format" in
  utm)
    image="$pkg_dir/basicsvm-${arch_name}-linux.qcow2"
    rm -f "$image"
    qemu-img convert -p -f raw -O qcow2 "$raw_path" "$image"
    qemu-img info "$image" > "$pkg_dir/qemu-img-info.txt"
    if [[ "$nix_system" == "aarch64-linux" ]]; then
      utm_zip="$("$repo_root/scripts/create-utm-bundle" "$image" "$pkg_dir" "bASICs-VM-Apple-Silicon" aarch64)"
    else
      utm_zip="$("$repo_root/scripts/create-utm-bundle" "$image" "$pkg_dir" "bASICs-VM-Intel-Mac" x86_64)"
    fi
    ;;
  virtualbox)
    image="$pkg_dir/basicsvm-${arch_name}-linux.vdi"
    rm -f "$image"
    qemu-img convert -p -f raw -O vdi "$raw_path" "$image"
    qemu-img info "$image" > "$pkg_dir/qemu-img-info.txt"
    if [[ "$ova" -eq 1 ]]; then
      ova_path="$pkg_dir/bASICs-VM-${arch_name}.ova"
      "$repo_root/scripts/create-virtualbox-appliance" "$image" "$ova_path"
    fi
    ;;
esac

cat > "$pkg_dir/README.txt" <<EOF
bASICs VM - $target

Recommended app: $([[ "$format" == "utm" ]] && echo "UTM" || echo "VirtualBox")
VM architecture: $nix_system
Login user: beaver
Password: works

Import/use the disk image in this folder:
$(basename "$image")

$([[ -n "$ova_path" ]] && cat <<OVA_TEXT

For VirtualBox, the preferred download is the bundled appliance:
$(basename "$ova_path")

Open VirtualBox, choose File -> Import Appliance, and select the .ova file.
OVA_TEXT
)

$([[ "$format" == "utm" ]] && cat <<UTM_TEXT

For Mac, the preferred download is the bundled UTM VM:
$(basename "$utm_zip")

Unzip it, then open the .utm bundle in UTM.
UTM_TEXT
)

Suggested VM resources:
- RAM: 8 GB minimum
- CPU: 4 cores minimum
- Disk: image virtual size is about 80 GiB

The VM contains the EDA toolchain, PDKs, examples, templates, and docs.
EOF

(
  cd "$out"
  : > checksums/SHA256SUMS
  if [[ "$raw_is_external" -ne 1 && -f raw/basicsvm-${arch_name}-linux.raw ]]; then
    sha256sum raw/basicsvm-${arch_name}-linux.raw > checksums/SHA256SUMS
  fi
  sha256sum "$format/$(basename "$image")" >> checksums/SHA256SUMS
  if [[ -n "$ova_path" ]]; then
    sha256sum "$format/$(basename "$ova_path")" >> checksums/SHA256SUMS
  fi
  if [[ "$format" == "utm" ]]; then
    sha256sum "$format/$(basename "$utm_zip")" >> checksums/SHA256SUMS
  fi
  sha256sum "$format/README.txt" >> checksums/SHA256SUMS
  if [[ -f raw/repart-output.json ]]; then
    sha256sum raw/repart-output.json >> checksums/SHA256SUMS
  fi
)

if [[ "$keep_raw" -ne 1 && "$raw_is_external" -ne 1 ]]; then
  rm -f "$raw_path"
fi

if [[ "$archive" -eq 1 ]]; then
  archive_path="$out/basicsvm-$target.tar.zst"
  rm -f "$archive_path"
  tar --zstd -cf "$archive_path" -C "$out" "$format" checksums
fi

cat <<EOF
Packaged $target
  image: $image
  info:  $pkg_dir/qemu-img-info.txt
  sums:  $checksum_dir/SHA256SUMS
EOF

if [[ "${archive:-0}" -eq 1 ]]; then
  echo "  archive: $archive_path"
fi
